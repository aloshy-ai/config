{
  "$schema": "https://raw.githubusercontent.com/jetify-com/devbox/0.14.0/.schema/devbox.schema.json",
  "packages": ["github:snowfallorg/flake", "nodePackages.prettier@latest"],
  "shell": {
    "init_hook": [
      "alias nix='nix --extra-experimental-features nix-command'",
      "alias darwin-rebuild='nix run github:LnL7/nix-darwin#darwin-rebuild'",
      "devbox run --list"
    ],
    "scripts": {
      "format": "nix fmt .",
      "switch-m2pro": "flake build-darwin m2pro",
      "switch-m3pro": "flake build-darwin m3pro",
      "build-rpi4": "nix build .#sd-aarch64Configurations.rpi4"
    }
  }
}
