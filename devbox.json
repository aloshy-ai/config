{
  "$schema": "https://raw.githubusercontent.com/jetify-com/devbox/0.14.0/.schema/devbox.schema.json",
  "packages": ["github:snowfallorg/flake", "nodePackages.prettier@latest"],
  "shell": {
    "init_hook": [
      "devbox run --list"
    ],
    "scripts": {
      "format": "nix fmt .",
      "switch-m2pro": "nix --extra-experimental-features 'nix-command flakes' run github:LnL7/nix-darwin#darwin-rebuild m2pro",
      "switch-m3pro": "nix --extra-experimental-features 'nix-command flakes' run github:LnL7/nix-darwin#darwin-rebuild m3pro",
      "build-rpi4": "nix --extra-experimental-features 'nix-command flakes' build .#sd-aarch64Configurations.rpi4"
    }
  }
}
